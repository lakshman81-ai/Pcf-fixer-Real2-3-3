    PIPE, LENGTH=1000MM, RefNo:=2, SeqNo:=2
PIPE
    END-POINT 1005 0 0 100
    END-POINT 2005 0 0 100
    COMPONENT-ATTRIBUTE1 TEST

MESSAGE-SQUARE
    FLANGE, LENGTH=50MM, RefNo:=3, SeqNo:=3
FLANGE
    END-POINT 2005 0 0 100
    END-POINT 2055 0 0 100

MESSAGE-SQUARE
    PIPE, LENGTH=1000MM, RefNo:=4, SeqNo:=4
PIPE
    END-POINT 2555 0 0 100
    END-POINT 3555 0 0 100

MESSAGE-SQUARE
