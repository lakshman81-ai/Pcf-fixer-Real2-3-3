ISOGEN-FILES ISOGEN.FLS
UNITS-BORE MM
UNITS-CO-ORDS MM

MESSAGE-SQUARE
    PIPE, LENGTH=1000MM, RefNo:=1, SeqNo:=1
PIPE
    END-POINT 0 0 0 200
    END-POINT 1000 0 0 200

MESSAGE-SQUARE
    TEE, LENGTH=200MM, RefNo:=2, SeqNo:=2
TEE
    END-POINT 1000 0 0 200
    END-POINT 1200 0 0 200
    CENTRE-POINT 9999.0 9999.0 9999.0 200

MESSAGE-SQUARE
    PIPE, LENGTH=1000MM, RefNo:=3, SeqNo:=3
PIPE
    END-POINT 1100 100 0 100
    END-POINT 1100 1100 0 100
