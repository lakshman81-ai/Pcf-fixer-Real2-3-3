ISOGEN-FILES ISOGEN.FLS
UNITS-BORE MM
UNITS-CO-ORDS MM

MESSAGE-SQUARE
    PIPE, LENGTH=1000MM, RefNo:=1, SeqNo:=1
PIPE
    END-POINT 0 0 0 100
    END-POINT 1000 0 0 100

MESSAGE-SQUARE
    PIPE, LENGTH=1000MM, RefNo:=2, SeqNo:=2
PIPE
    END-POINT 1010 20 15 100
    END-POINT 2010 20 15 100

MESSAGE-SQUARE
    FLANGE, LENGTH=50MM, RefNo:=3, SeqNo:=3
FLANGE
    END-POINT 2010 20 15 100
    END-POINT 2060 20 15 100

MESSAGE-SQUARE
    VALVE, LENGTH=200MM, RefNo:=4, SeqNo:=4
VALVE
    END-POINT 2120 20 15 100
    END-POINT 2320 20 15 100
